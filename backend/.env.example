# Development environment variables
# Copy this file to .env and update values

# Application
APP_NAME="Holiday Calendar"
DEBUG=true
ENVIRONMENT=development

# Server (used by uvicorn/Docker, not by the FastAPI app directly)
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (SQLite for development)
DATABASE_URL=sqlite:///./holiday_calendar.db

# Microsoft Azure AD (Optional - for Microsoft 365 login)
# AZURE_CLIENT_ID=your-azure-client-id
# AZURE_CLIENT_SECRET=your-azure-client-secret
# AZURE_TENANT_ID=your-azure-tenant-id
# AZURE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# URLs
FRONTEND_URL=http://localhost:5173
# BACKEND_URL is currently not used in the application code
# It's here for future use (webhooks, email links, etc.)
BACKEND_URL=http://localhost:8000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Default Admin (created on first start if no users exist)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
